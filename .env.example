# MongoDB — same URI as forg-app (same database, same collections)
MONGODB_URI=mongodb+srv://...

# Upstash Redis — same instance as forg-app (shared rate limit store)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Domain
NEXT_PUBLIC_API_URL=https://api.forg.to
NEXT_PUBLIC_APP_URL=https://forg.to
